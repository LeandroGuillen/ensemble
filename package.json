{
  "name": "ensemble",
  "version": "0.5.4",
  "description": "Character management application for writers and worldbuilders",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "electron": "electron .",
    "electron-dev": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && electron .\"",
    "electron-prod": "ng build --configuration production && electron .",
    "build-electron": "ng build --configuration production && electron-builder",
    "build-electron-all": "ng build --configuration production && electron-builder --mac --win --linux",
    "build-electron-mac": "ng build --configuration production && electron-builder --mac",
    "build-electron-win": "ng build --configuration production && electron-builder --win",
    "build-electron-linux": "ng build --configuration production && electron-builder --linux",
    "build-electron-linux-appimage": "ng build --configuration production && electron-builder --linux AppImage",
    "build-electron-linux-deb": "ng build --configuration production && electron-builder --linux deb",
    "build-electron-linux-rpm": "ng build --configuration production && electron-builder --linux rpm",
    "dist": "npm run build-electron-all",
    "build-icons": "node scripts/build-icons.js",
    "prebuild-electron": "npm run build-icons",
    "test": "ng test --watch=false",
    "test-electron": "electron test-electron.js",
    "verify": "node verify-setup.js",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "keywords": [
    "character-management",
    "worldbuilding",
    "writing",
    "electron",
    "angular"
  ],
  "author": {
    "name": "Leandro Guillen",
    "email": "hi@leandroguillen.com"
  },
  "homepage": "https://github.com/ensemble/ensemble",
  "repository": {
    "type": "git",
    "url": "https://github.com/ensemble/ensemble.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0",
    "electron-icon-builder": "^2.0.1",
    "typescript": "~5.2.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@angular/animations": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/router": "^17.0.0",
    "chokidar": "^3.5.0",
    "js-yaml": "^4.1.0",
    "remark": "^15.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "unified": "^11.0.0",
    "vis-network": "^9.1.0",
    "zone.js": "~0.14.0"
  },
  "build": {
    "appId": "com.ensemble.app",
    "productName": "Ensemble",
    "copyright": "Copyright © 2025 Ensemble",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!node_modules/@angular/cli",
      "!node_modules/@angular-devkit",
      "!node_modules/typescript",
      "!node_modules/electron-builder",
      "!node_modules/concurrently",
      "!node_modules/wait-on"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "publisherName": "Ensemble",
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "desktop": {
        "Name": "Ensemble",
        "Comment": "Character management for writers and worldbuilders",
        "Keywords": "writing;characters;worldbuilding;story;"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ensemble"
    },
    "dmg": {
      "title": "Ensemble ${version}",
      "backgroundColor": "#2c3e50",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 410,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 190,
          "type": "file"
        }
      ]
    },
    "publish": null
  }
}
